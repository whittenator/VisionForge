    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.12.0",
    "eslint-plugin-react": "^7.37.1",
    "prettier": "^3.3.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^5.4.8"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.27.0"
