# Monorepo gitignore (Python + Node + Dev Tools)

# 1) Environment files
.env
.env.*
!.env.example
.github

# 2) Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
htmlcov/
.coverage
.coverage.*
coverage.xml

# SQLite / local DBs
*.db
*.sqlite
*.sqlite3
test.db

# 3) Node / Frontend (Vite/React/Tailwind/Playwright)
node_modules/
pnpm-lock.yaml
package-lock.json
*.tsbuildinfo
.vite/
vite.cache/
frontend/dist/
dist/
playwright-report/
frontend/playwright-report/
test-results/
frontend/test-results/

# 4) Editors / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.code-workspace

# 5) Docker
docker-data/
.docker/

# 6) Logs & temp
*.log
logs/
tmp/
.cache/

# 7) Misc
.ipynb_checkpoints/
.envrc