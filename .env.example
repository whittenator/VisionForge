# Core environment variables for VisionForge (copy to .env and fill values)

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=visionforge
POSTGRES_USER=visionforge
POSTGRES_PASSWORD=change-me

# MinIO (S3 compatible)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=miniokey
MINIO_SECRET_KEY=miniosecret
MINIO_SECURE=false
MINIO_DISABLED=false
S3_BUCKET=visionforge
MINIO_PRESIGN_EXPIRY_SECONDS=3600

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=change-me-super-secret-must-be-at-least-32-characters-long
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SKIP_DB_MIGRATIONS=false

# JWT Auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Observability
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Superuser (created on backend startup)
SUPERUSER_EMAIL=admin@visionforge.local
SUPERUSER_PASSWORD=change-me-superuser

# ML / Training
SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001
YOLO_BASE_MODEL=yolov8n.pt
MAX_TRAINING_EPOCHS=300
