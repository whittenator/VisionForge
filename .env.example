# Core environment variables for VisionForge (copy to .env and fill values)

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=visionforge
POSTGRES_USER=visionforge
POSTGRES_PASSWORD=change-me

# MinIO (S3 compatible)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=miniokey
MINIO_SECRET_KEY=miniosecret
S3_BUCKET=visionforge

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=change-me-super-secret
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Superuser (created on backend startup)
SUPERUSER_EMAIL=admin@visionforge.local
SUPERUSER_PASSWORD=change-me
